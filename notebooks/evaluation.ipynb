    "    \n",
    "    text = str(row['tweet_text']).lower()\n",
    "    \n",
    "    if any(word in text for word in ['apple', 'ipad', 'iphone', 'mac']):\n",
    "        return 'Apple'\n",
    "    elif any(word in text for word in ['google', 'android', 'pixel']):\n",
    "        return 'Google'\n",
    "    else:\n",
    "        return 'Not specified'\n",
